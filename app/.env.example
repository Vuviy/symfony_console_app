###> app/console ###
APP_ENV=dev
APP_DEBUG=1
APP_NAME="Console Application"
APP_VERSION=1.0.0
###< app/console ###

###> backup ###
# Full DSN used by app:backup when no argument is passed
DATABASE_URL=mysql://user:password@127.0.0.1:3306/mydb

# Directory where .sql.gz dump files are stored
BACKUP_DIR=/var/backups/app

# Override binary paths if mysqldump / gzip are not on $PATH
#MYSQLDUMP_BIN=mysqldump
#GZIP_BIN=gzip
###< backup ###

###> logging ###
# Minimum log level written to stdout/stderr (DEBUG, INFO, NOTICE, WARNING, ERROR)
LOG_LEVEL=INFO

# Set to any value to disable ANSI colors (useful for CI log capture)
#NO_COLOR=1
###< logging ###