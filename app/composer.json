{
    "name": "app/console",
    "description": "Symfony Console Application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "symfony/console": "^6.4",
        "symfony/dotenv": "^6.4",
        "psr/log": "^3.0",
      "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "console": "php bin/console",
        "test": "php vendor/bin/phpunit",
        "test:unit": "php vendor/bin/phpunit --testsuite=Unit",
        "test:integration": "php vendor/bin/phpunit --testsuite=Integration",
        "test:functional": "php vendor/bin/phpunit --testsuite=Functional"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
